#!/bin/sh
set -e

PACKAGE_DATA_DIR="/usr/lib/folder-color"
EXTENSIONS_DIR="/usr/share/nautilus-python/extensions"
TARGET_EXTENSION="${EXTENSIONS_DIR}/folder-color.py"
LEGACY_GTK3_EXTENSION="${EXTENSIONS_DIR}/GTK3.py"
LEGACY_GTK4_EXTENSION="${EXTENSIONS_DIR}/GTK4.py"

install_extension() {
    mkdir -p "$EXTENSIONS_DIR"
    cat > "$TARGET_EXTENSION" <<EOF
import importlib
import importlib.util
import os

import gi

gi.require_version("GIRepository", "2.0")
from gi.repository import GIRepository

BROWSER_NAMESPACE = "Nautilus"


def _load_browser_namespace():
    return importlib.import_module("gi.repository." + BROWSER_NAMESPACE)


def _get_preferred_modules():
    repo = GIRepository.Repository.get_default()

    if "Gtk" in repo.get_loaded_namespaces():
        gtk_version = repo.get_version("Gtk")
        if gtk_version.startswith("3"):
            return ("GTK3.py", "GTK4.py")
        if gtk_version.startswith("4"):
            return ("GTK4.py", "GTK3.py")

    return ("GTK4.py", "GTK3.py")


def _load_module(module_name):
    module_path = os.path.join("${PACKAGE_DATA_DIR}", "extensions", module_name)
    spec = importlib.util.spec_from_file_location(__name__ + "_impl", module_path)

    if spec is None or spec.loader is None:
        raise ImportError("Unable to load Folder Color extension")

    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    return module


last_error = None
_load_browser_namespace()
for module_name in _get_preferred_modules():
    try:
        module = _load_module(module_name)
        break
    except (ImportError, ValueError) as error:
        last_error = error
else:
    raise last_error

for name, value in module.__dict__.items():
    if name.startswith("__") and name not in ("__doc__", "__all__"):
        continue
    globals()[name] = value
EOF
    chmod 0644 "$TARGET_EXTENSION"
}

remove_legacy_extensions() {
    rm -f "$LEGACY_GTK3_EXTENSION" "$LEGACY_GTK4_EXTENSION"
}

deploy_yaru_icons() {
    source_dir="${PACKAGE_DATA_DIR}/icons/Yaru"
    target_dir="/usr/share/icons/Yaru"

    if [ -d "$target_dir" ] && [ -d "$source_dir" ]; then
        cp -a "${source_dir}/." "$target_dir/"
        gtk-update-icon-cache "$target_dir" || true
    fi
}

remove_legacy_extensions
install_extension

deploy_yaru_icons

if [ -d /usr/share/icons/hicolor ]; then
    gtk-update-icon-cache /usr/share/icons/hicolor/ || true
fi
