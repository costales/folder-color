#!/bin/sh
set -e

EXTENSIONS_DIR="/usr/share/folder-color/extensions"
EXTENSION_LINK="/usr/share/nautilus-python/extensions/folder-color.py"
PACKAGE_YARU_DIR="/usr/share/folder-color/icons/Yaru"
SYSTEM_YARU_DIR="/usr/share/icons/Yaru"

select_extension() {
    if ldconfig -p 2>/dev/null | grep -q 'libgtk-3\.so'; then
        printf '%s\n' "$EXTENSIONS_DIR/gtk3/extension.py"
    else
        printf '%s\n' "$EXTENSIONS_DIR/gtk4/extension.py"
    fi
}

install -d "$(dirname "$EXTENSION_LINK")"
ln -sf "$(select_extension)" "$EXTENSION_LINK"

if [ -d "$SYSTEM_YARU_DIR" ] && [ -d "$PACKAGE_YARU_DIR" ]; then
    cp -a "$PACKAGE_YARU_DIR"/. "$SYSTEM_YARU_DIR"/
    gtk-update-icon-cache "$SYSTEM_YARU_DIR"
fi

gtk-update-icon-cache /usr/share/icons/hicolor/
